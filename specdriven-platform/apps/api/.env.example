# Local development only — credentials match docker-compose.yml
DATABASE_URL="postgresql://specdriven:specdriven@localhost:5432/specdriven?schema=public"
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Auth stubs (Phase A)
DEV_AUTH_BYPASS=false
JWT_SECRET=dev-only-change-me

# Fase C
APP_PUBLIC_URL=http://localhost:5173
MAIL_PROVIDER=log
MAIL_FROM=noreply@specdriven.local
# Mailpit local: docker compose up -d mailpit → UI :8025 / SMTP :1025
# MAIL_PROVIDER=smtp
# SMTP_HOST=127.0.0.1
# SMTP_PORT=1025
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=specdriven
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
UPLOAD_MAX_BYTES=10485760
