generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  master
  admin
  gestor
  consultor
  cliente
}

enum TicketStatus {
  backlog
  em_andamento
  aguardando_cliente
  em_teste
  concluido
  cancelado
}

enum CommentVisibility {
  public
  internal
}

enum ApprovalKind {
  ticket
  hour_limit
  time_entry
  change
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum TicketType {
  melhoria
  incidente
  duvida
  problema
}

enum ProblemStatus {
  investigating
  identified
  known_error
  closed
}

enum ChangeStatus {
  draft
  pending_approval
  approved
  rejected
  implementing
  completed
  failed
}

enum ArticleStatus {
  draft
  published
  archived
}

enum OfferingStatus {
  active
  draft
  retired
}

enum RiskStatus {
  open
  mitigated
  accepted
  closed
}

enum BillingModel {
  per_hour
  per_ticket
  fixed_project
}

enum SupportTier {
  N1
  N2
  N3
}

model Organization {
  id                  String   @id @default(uuid())
  name                String
  /// Consultoria master da plataforma (ex. Blend IT).
  isMasterConsultancy Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  clients          Client[]
  users            User[]
  tickets          Ticket[]
  invites          Invite[]
  timeEntries      TimeEntry[]
  tags             Tag[]
  slaPolicies      SlaPolicy[]
  approvalRequests ApprovalRequest[]
  notifications    Notification[]
  auditEvents      AuditEvent[]
  projects         Project[]
  settings         OrganizationSettings?
  moduleCatalog    TicketModuleCatalog[]
  holidays         OrganizationHoliday[]
  problems         Problem[]
  changes          Change[]
  articles         Article[]
  serviceOfferings ServiceOffering[]
  risks            Risk[]

  @@map("organizations")
}

model OrganizationSettings {
  organizationId     String   @id
  supportEmail       String?
  /// Texto curto exibido no footer do portal cliente (2–3 linhas).
  supportPolicyText  String?
  /// Subset habilitado de TicketType (CSV).
  enabledTicketTypes String   @default("melhoria,incidente,duvida,problema")
  /// Meta de cumprimento SLA (%) exibida em dashboards.
  slaTargetPct       Int      @default(90)
  /// JSON: { businessHourStart, businessHourEnd, weekdays } — template para novas políticas.
  defaultBusinessHoursJson String?
  /// Nome exibido no From: dos e-mails transacionais.
  emailFromName      String?
  /// Reply-To dos e-mails transacionais.
  emailReplyTo       String?
  /// Rodapé opcional nos templates de e-mail.
  emailFooterText    String?
  knowledgeBaseEnabled Boolean @default(false)
  knowledgeBaseUrl   String?
  /// Matriz evento × canal (JSON).
  notificationPrefsJson String @default("{}")
  /// Chave S3 do logo (org branding).
  logoStorageKey     String?
  /// Título do hero no portal cliente.
  portalHeroTitle    String?
  /// Subtítulo do hero no portal cliente.
  portalHeroSubtitle String?
  /// SMTP próprio da consultoria (P2).
  smtpEnabled        Boolean  @default(false)
  smtpHost           String?
  smtpPort           Int?
  smtpUser           String?
  smtpPass           String?
  smtpFrom           String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_settings")
}

model OrganizationHoliday {
  id             String   @id @default(uuid())
  organizationId String
  date           DateTime @db.Date
  name           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, date])
  @@index([organizationId])
  @@map("organization_holidays")
}

model TicketModuleCatalog {
  id             String   @id @default(uuid())
  organizationId String
  key            String
  label          String
  sortOrder      Int      @default(0)
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@index([organizationId])
  @@map("ticket_module_catalog")
}

model Client {
  id                  String   @id @default(uuid())
  organizationId      String
  name                String
  code                String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users        User[]
  tickets      Ticket[]
  invites      Invite[]
  slaPolicies  SlaPolicy[]
  projects     Project[]

  @@index([organizationId])
  @@map("clients")
}

model Project {
  id                 String       @id @default(uuid())
  organizationId     String
  clientId           String
  name               String
  code               String       // Prefixo da key do ticket (ex: AVBIO)
  billingModel       BillingModel @default(per_hour)
  baselineHoursMonth Float?
  hourlyRateCents    Int?
  ticketRateCents    Int?
  budgetCents        Int?
  startDate          DateTime?    @db.Date
  endDate            DateTime?    @db.Date
  slaActiveStatuses  String       @default("em_andamento")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  organization      Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client            Client                    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userProjects      UserProject[]
  tickets           Ticket[]
  moduleAssignments ProjectModuleAssignment[]

  @@index([organizationId])
  @@index([clientId])
  @@map("projects")
}

model User {
  id             String   @id @default(uuid())
  organizationId String
  email          String
  name           String
  passwordHash   String
  role           UserRole
  clientId       String?
  /// Fator de taxa hora do consultor (ex. 1.2 = +20%).
  hourRateFactor Float    @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization       Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client             Client?                   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  assignedTickets    Ticket[]                  @relation("TicketAssignee")
  comments           Comment[]
  timeEntries        TimeEntry[]
  statusChanges      TicketStatusHistory[]     @relation("StatusChangedBy")
  requestedApprovals ApprovalRequest[]         @relation("ApprovalRequester")
  reviewedApprovals  ApprovalRequest[]         @relation("ApprovalReviewer")
  notifications      Notification[]
  userProjects       UserProject[]
  moduleAssignments  ProjectModuleAssignment[] @relation("ModuleAssignments")

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([clientId])
  @@map("users")
}

model Ticket {
  id                    String       @id @default(uuid())
  organizationId        String
  clientId              String
  projectId             String
  key                   String
  title                 String
  description           String?
  status                TicketStatus @default(backlog)
  priority              String?
  assigneeId            String?
  estimateMinutes       Int?
  /// Limite de horas (minutos) definido pelo gestor; exceder exige aprovação.
  hourLimitMinutes      Int?
  ticketType            TicketType   @default(melhoria)
  /// Nome da empresa informado pelo cliente na abertura.
  companyName           String?
  /// Módulo/área do sistema (lista configurável no shared).
  module                String?
  countsTowardBaseline  Boolean      @default(true)
  /// Prazo SLA de resolução (horas úteis do client).
  slaDueAt              DateTime?
  slaPausedTotalMinutes Int          @default(0)
  csatScore             Int?
  csatComment           String?
  serviceOfferingId     String?
  firstResponseAt       DateTime?
  resolvedAt            DateTime?
  deletedAt             DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  organization     Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client           Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project          Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  serviceOffering  ServiceOffering?      @relation(fields: [serviceOfferingId], references: [id], onDelete: SetNull)
  assignee         User?                 @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  comments         Comment[]
  attachments      Attachment[]
  timeEntries      TimeEntry[]
  ticketTags       TicketTag[]
  statusHistory    TicketStatusHistory[]
  approvalRequests ApprovalRequest[]
  problemIncidents ProblemIncident[]

  @@unique([organizationId, key])
  @@index([organizationId])
  @@index([clientId])
  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
  @@index([slaDueAt])
  @@index([deletedAt])
  @@map("tickets")
}

model Comment {
  id         String            @id @default(uuid())
  ticketId   String
  authorId   String
  body       String
  visibility CommentVisibility @default(public)
  createdAt  DateTime          @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([authorId])
  @@map("comments")
}

model Attachment {
  id         String   @id @default(uuid())
  ticketId   String
  storageKey String
  fileName   String
  mimeType   String?
  sizeBytes  Int?
  createdAt  DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("attachments")
}

model Invite {
  id             String    @id @default(uuid())
  organizationId String
  email          String
  role           UserRole
  clientId       String?
  token          String    @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([email])
  @@map("invites")
}

/// Time tracking (Fase C — aprovações de horas / limite por ticket).
model TimeEntry {
  id             String         @id @default(uuid())
  organizationId String
  ticketId       String
  userId         String
  startedAt      DateTime
  endedAt        DateTime?
  seconds        Int?
  note           String?
  /// pending quando excede limite e aguarda gestor; approved caso contrário.
  approvalStatus ApprovalStatus @default(approved)
  createdAt      DateTime       @default(now())

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ticket           Ticket            @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvalRequests ApprovalRequest[]

  @@index([organizationId])
  @@index([ticketId])
  @@index([userId])
  @@index([approvalStatus])
  @@map("time_entries")
}

/// Workflow de aprovação: chamado (ex. fechar), limite de horas, lançamento de horas.
model ApprovalRequest {
  id               String         @id @default(uuid())
  organizationId   String
  kind             ApprovalKind
  status           ApprovalStatus @default(pending)
  ticketId         String?
  timeEntryId      String?
  changeId         String?
  requesterId      String
  reviewerId       String?
  /// Status alvo do chamado (kind=ticket), ex. concluido.
  targetStatus     TicketStatus?
  /// Novo limite solicitado em minutos (kind=hour_limit).
  requestedMinutes Int?
  reason           String?
  decisionNote     String?
  decidedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ticket       Ticket?      @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  timeEntry    TimeEntry?   @relation(fields: [timeEntryId], references: [id], onDelete: SetNull)
  change       Change?      @relation("ChangeApprovals", fields: [changeId], references: [id], onDelete: SetNull)
  requester    User         @relation("ApprovalRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  reviewer     User?        @relation("ApprovalReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([ticketId])
  @@index([status])
  @@index([kind])
  @@index([requesterId])
  @@map("approval_requests")
}

/// Tags de ticket (Fase E — ownership SLA/tags).
model Tag {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  color          String?
  /// Exibir no portal cliente no detalhe do chamado.
  visibleToClient Boolean @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ticketTags   TicketTag[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("tags")
}

model TicketTag {
  ticketId  String
  tagId     String
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([ticketId, tagId])
  @@index([tagId])
  @@map("ticket_tags")
}

/// Política SLA por org/cliente (Fase E — ownership SLA/tags).
model SlaPolicy {
  id                 String   @id @default(uuid())
  organizationId     String
  clientId           String
  name               String
  /// Match de prioridade do ticket; vazio = default do cliente.
  priorityMatch      String   @default("")
  responseMinutes    Int
  resolutionMinutes  Int
  businessHourStart  Int      @default(9)
  businessHourEnd    Int      @default(18)
  /// Dias da semana 0=Dom … 6=Sáb, CSV (ex. 1,2,3,4,5).
  weekdays           String   @default("1,2,3,4,5")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  serviceOfferings ServiceOffering[]

  @@unique([clientId, priorityMatch])
  @@index([organizationId])
  @@index([clientId])
  @@map("sla_policies")
}

/// Histórico de mudanças de status (Fase E — ownership SLA/tags).
model TicketStatusHistory {
  id          String        @id @default(uuid())
  ticketId    String
  fromStatus  TicketStatus?
  toStatus    TicketStatus
  changedById String
  note        String?
  createdAt   DateTime      @default(now())

  ticket    Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  changedBy User   @relation("StatusChangedBy", fields: [changedById], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([changedById])
  @@map("ticket_status_history")
}

model Notification {
  id             String    @id @default(uuid())
  organizationId String
  userId         String
  title          String
  body           String?
  href           String?
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId])
  @@index([userId, readAt])
  @@map("notifications")
}

model AuditEvent {
  id             String   @id @default(uuid())
  organizationId String
  actorId        String?
  action         String
  entityType     String
  entityId       String?
  metaJson       String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([entityType])
  @@map("audit_events")
}

model UserProject {
  id        String   @id @default(uuid())
  userId    String
  projectId String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
  @@map("user_projects")
}

model ProjectModuleAssignment {
  id        String      @id @default(uuid())
  projectId String
  module    String
  userId    String
  tier      SupportTier @default(N1)
  createdAt DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation("ModuleAssignments", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, module, userId])
  @@index([projectId, module])
  @@index([userId])
  @@map("project_module_assignments")
}

model Problem {
  id              String        @id @default(uuid())
  organizationId  String
  title           String
  description     String?
  status          ProblemStatus @default(investigating)
  rootCause       String?
  workaround      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  incidents    ProblemIncident[]
  changes      Change[]
  articles     Article[]
  risks        Risk[]

  @@index([organizationId])
  @@index([status])
  @@map("problems")
}

model ProblemIncident {
  problemId String
  ticketId  String
  createdAt DateTime @default(now())

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  ticket  Ticket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@id([problemId, ticketId])
  @@index([ticketId])
  @@map("problem_incidents")
}

model Change {
  id            String            @id @default(uuid())
  organizationId String
  title         String
  description   String?
  status        ChangeStatus      @default(draft)
  riskScore     Int               @default(1)
  rollbackPlan  String?
  windowStart   DateTime?
  windowEnd     DateTime?
  cabDecision   String?
  cabDecisionNote String?
  cabDecisionAt DateTime?
  problemId     String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  problem      Problem?          @relation(fields: [problemId], references: [id], onDelete: SetNull)
  approvals    ApprovalRequest[] @relation("ChangeApprovals")
  risks        Risk[]

  @@index([organizationId])
  @@index([problemId])
  @@index([status])
  @@map("changes")
}

model Article {
  id              String        @id @default(uuid())
  organizationId  String
  title           String
  body            String
  status          ArticleStatus @default(draft)
  visibleToClient Boolean       @default(false)
  problemId       String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  problem      Problem?     @relation(fields: [problemId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([status])
  @@index([problemId])
  @@map("articles")
}

model ServiceOffering {
  id               String         @id @default(uuid())
  organizationId   String
  name             String
  description      String?
  slaPolicyId      String?
  requiresApproval Boolean        @default(false)
  status           OfferingStatus @default(draft)
  version          Int            @default(1)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  slaPolicy    SlaPolicy?   @relation(fields: [slaPolicyId], references: [id], onDelete: SetNull)
  tickets      Ticket[]

  @@index([organizationId])
  @@index([status])
  @@map("service_offerings")
}

model Risk {
  id             String     @id @default(uuid())
  organizationId String
  title          String
  description    String?
  probability    String     @default("medium")
  impact         String     @default("medium")
  mitigation     String?
  status         RiskStatus @default(open)
  changeId       String?
  problemId      String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  change       Change?      @relation(fields: [changeId], references: [id], onDelete: SetNull)
  problem      Problem?     @relation(fields: [problemId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([status])
  @@map("risks")
}
