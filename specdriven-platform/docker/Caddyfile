# Reverse proxy TLS — ajuste domínios antes do deploy.
# Uso: caddy run --config docker/Caddyfile (na pasta specdriven-platform)

{
	email admin@exemplo.com
}

api.exemplo.com {
	reverse_proxy localhost:3000
}

portal.exemplo.com {
	reverse_proxy localhost:8080
}

staff.exemplo.com {
	reverse_proxy localhost:8081
}
