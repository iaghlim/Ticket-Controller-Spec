# Copie para .env e preencha com valores reais antes do deploy.
# Nunca versione .env com secrets.

NODE_ENV=production

# --- Postgres (docker-compose.prod.yml ou serviço gerenciado) ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public

# --- API ---
PORT=3000
HOST=0.0.0.0
API_PORT=3000

# Origens CORS permitidas (URLs dos portais, separadas por vírgula)
CORS_ORIGINS=https://portal.exemplo.com,https://staff.exemplo.com

# Secret JWT — mínimo 32 caracteres; gere com: openssl rand -base64 48
JWT_SECRET=

# URL pública do portal cliente (links em convites/e-mail)
APP_PUBLIC_URL=https://portal.exemplo.com
APP_STAFF_URL=https://staff.exemplo.com

# Rate limit de login (tentativas por IP por minuto)
LOGIN_RATE_LIMIT=30

# Upload máximo em bytes (padrão 10 MiB)
UPLOAD_MAX_BYTES=10485760

# --- Portais (build-time Vite + portas do compose) ---
VITE_API_URL_CLIENT=https://api.exemplo.com
VITE_API_URL_STAFF=https://api.exemplo.com
WEB_CLIENT_PORT=8080
WEB_STAFF_PORT=8081

MAIL_PROVIDER=smtp
MAIL_FROM=noreply@exemplo.com
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# --- Object storage (S3 ou MinIO) ---
# Com profile storage no compose: S3_ENDPOINT=http://minio:9000
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=specdriven
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# true para MinIO / compatíveis; false para AWS S3
S3_FORCE_PATH_STYLE=true
