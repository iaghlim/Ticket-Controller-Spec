# Local development only — copy to .env and adjust if needed.
# Postgres credentials match docker-compose.yml (specdriven/specdriven/specdriven).

DATABASE_URL="postgresql://specdriven:specdriven@localhost:5432/specdriven?schema=public"

# API
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Auth stub (local only)
# When true: POST /auth/login returns token "dev-token" without DB.
# Blocked at startup when NODE_ENV=production.
DEV_AUTH_BYPASS=false
# Required in production: ≥ 32 chars, not "dev-only-change-me".
JWT_SECRET=dev-only-change-me

# CORS (comma-separated origins). Required in production.
# Dev default when unset: localhost:5173 (client) + :5174 (staff).
# CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# OpenAPI /docs — disabled in production unless one of:
# OPENAPI_ENABLED=true  (public docs; use only on trusted networks)
# OPENAPI_USER=admin + OPENAPI_PASSWORD=...  (basic auth on /docs)
# OPENAPI_ENABLED=false

# Invite tokens in API responses (POST/GET /invites). Omitted in production unless:
# INVITE_RETURN_TOKEN=true

# Public URL used in invite e-mails (portal)
APP_PUBLIC_URL=http://localhost:5173
# Portal staff — links de reset de senha para gestor/consultor
APP_STAFF_URL=http://localhost:5174

# Bootstrap master (banco limpo, sem demo) — ver scripts/reset-local.ps1
# MASTER_EMAIL=seu@email.com
# MASTER_PASSWORD=senha-forte-aqui
# MASTER_NAME=Seu Nome
# ORG_NAME=Blend IT

MAIL_PROVIDER=log
MAIL_FROM=noreply@specdriven.local
# Local Mailpit (docker compose service `mailpit`): UI http://localhost:8025
# SMTP_HOST=127.0.0.1
# SMTP_PORT=1025
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# To use SMTP locally: MAIL_PROVIDER=smtp + SMTP_* above

# Object storage (MinIO local — docker compose service `minio`)
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=specdriven
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
UPLOAD_MAX_BYTES=10485760
